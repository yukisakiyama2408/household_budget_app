generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  content   String
  category  String?
  amount    Int
  type      String
  payMethod String?
  store     String?
  createdAt DateTime @default(now())
}

model Budget {
  id       Int    @id @default(autoincrement())
  year     Int
  month    Int
  category String
  amount   Int

  @@unique([year, month, category])
}
